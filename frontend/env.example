# Local: use localhost. On Vercel you MUST set these in the dashboard (not only in this file).
# Production API (Render): must match the Render service URL you deploy (no trailing slash).
# If you create a new Render service, update Vercel and redeploy the frontend.
# NEXT_PUBLIC_API_URL=https://your-service.onrender.com
# NEXT_PUBLIC_SOCKET_URL=https://your-service.onrender.com

NEXT_PUBLIC_API_URL=https://canvasquillapp.onrender.com ,http://localhost:5000
