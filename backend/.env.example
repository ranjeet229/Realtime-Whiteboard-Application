PORT=5000
NODE_ENV=development

# Merged into one allowlist (no wildcard). FRONTEND_URL = single origin only.
# CORS_ORIGINS = comma-separated list. Trailing slashes are stripped.
# Production-only example:
#   FRONTEND_URL=https://canvasapp-beryl.vercel.app
# Production + local dev:
#   CORS_ORIGINS=https://canvasapp-beryl.vercel.app,http://localhost:3000
FRONTEND_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000

# Required. From MongoDB Atlas: Database → Connect → Drivers → copy URI
# Replace <password> and set a database name (e.g. canvasquill)
# Example Atlas:
# MONGODB_URI=mongodb+srv://USER:PASSWORD@cluster0.xxxxx.mongodb.net/canvasquill?retryWrites=true&w=majority
# Example local:
# MONGODB_URI=mongodb://127.0.0.1:27017/canvasquill
MONGODB_URI=

# Required for signing room tokens used by Socket.IO
JWT_SECRET=change-me-to-a-long-random-string-at-least-32-characters
ROOM_TOKEN_EXPIRES_IN=7d
